# Public env vars (commit safe values only — empty here)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# If you deploy the static site on GitHub Pages and the dynamic backend
# elsewhere (e.g. Cloudflare Worker, Vercel Function), set this to that
# backend's POST endpoint. Leave empty when running both locally.
NEXT_PUBLIC_SIGN_ENDPOINT=

# Cloudflare Turnstile site key (public, safe to expose).
# Get one free at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Server-only (do NOT commit real values) -------------------------------
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile secret key (server-side verification)
TURNSTILE_SECRET_KEY=

# Salt for hashing IPs (>= 32 random chars). Used for rate limiting + abuse
# detection without storing real IPs. NEVER commit a real value.
OTP_PEPPER=

# Optional: Upstash Redis for distributed rate limiting (replaces in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
