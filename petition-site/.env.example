# Public env vars (commit safe values only — empty here)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# If you deploy the static site on GitHub Pages and the dynamic backend
# elsewhere (e.g. Cloudflare Worker, Vercel Function), set this to that
# backend's base URL. Leave empty when running both locally.
NEXT_PUBLIC_SIGN_ENDPOINT=

# --- Server-only (do NOT commit real values) -------------------------------
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=StandUp <noreply@example.com>

# OTP signing pepper (>= 32 random chars). NEVER commit a real value.
OTP_PEPPER=

# Optional: Upstash Redis for distributed rate limiting (replaces in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: reCAPTCHA v3
RECAPTCHA_SECRET=
